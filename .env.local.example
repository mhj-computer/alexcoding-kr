# ==========================================
# Supabase
# ==========================================
# 프로젝트 URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# service_role 키 — 서버 전용, 절대 클라이언트 번들에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# JWT 세션
# ==========================================
# 생성: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-48-bytes
JWT_EXPIRES_IN=7d

# ==========================================
# 관리자 마스터 키
# ==========================================
# 로그인 폼 "이름" 필드에 ADMIN_NAME, "생년월일" 필드에 ADMIN_BIRTH 입력 시 관리자 진입
ADMIN_NAME=mhj331212
ADMIN_BIRTH=iloveyou1!

# ==========================================
# 푸터 연락처
# ==========================================
NEXT_PUBLIC_KAKAO_OPENCHAT=https://open.kakao.com/o/s7DlmJri
NEXT_PUBLIC_PHONE=010-8637-3734

# ==========================================
# 시스템
# ==========================================
NODE_ENV=development
